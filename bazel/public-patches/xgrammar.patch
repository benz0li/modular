+      "$id",         "$schema",      "$defs",             "definitions",
+      "$anchor",     "$vocabulary",  "$dynamicAnchor",    "$recursiveAnchor",
+      "contentEncoding", "contentMediaType", "contentSchema",
+      "if",          "then",         "else"};
+  return kNoConstraintKeywords;
+}
