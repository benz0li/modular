+// Returns true if `json_str` parses as a JSON object, false otherwise.
+bool IsJsonObjectLiteral(const std::string& json_str) {
+  picojson::value v;
+  std::string err = picojson::parse(v, json_str);
+  return err.empty() && v.is<picojson::object>();
+}
+
+// Whether the schema spec can ONLY produce a JSON object (used for nested
+// require_object_root checks; does not coerce). Recurses through Ref/AnyOf/
+// AllOf/TypeArray. Cycles through $ref are treated conservatively as an error.
+Result<bool, SchemaError> MustBeObject(
+    const SchemaSpecPtr& spec,
+    const JSONSchemaConverter::RefResolver& resolver,
+    std::unordered_set<std::string>& visited_refs
+) {
+  return std::visit(
+      [&](const auto& s) -> Result<bool, SchemaError> {
+        using T = std::decay_t<decltype(s)>;
+        if constexpr (std::is_same_v<T, ObjectSpec>) {
+          return ResultOk(true);
+        } else if constexpr (std::is_same_v<T, AnySpec>) {
+          // Nested Any is not coerced: it can be a non-object, so it is not
+          // guaranteed to be an object.
+          return ResultOk(false);
+        } else if constexpr (std::is_same_v<T, ConstSpec>) {
+          return ResultOk(IsJsonObjectLiteral(s.json_value));
+        } else if constexpr (std::is_same_v<T, EnumSpec>) {
+          for (const auto& v : s.json_values) {
+            if (!IsJsonObjectLiteral(v)) return ResultOk(false);
+          }
+          return ResultOk(!s.json_values.empty());
+        } else if constexpr (std::is_same_v<T, TypeArraySpec>) {
+          for (const auto& sub : s.type_schemas) {
+            auto r = MustBeObject(sub, resolver, visited_refs);
+            if (r.IsErr()) return ResultErr(std::move(r).UnwrapErr());
+            if (!std::move(r).Unwrap()) return ResultOk(false);
+          }
+          return ResultOk(!s.type_schemas.empty());
+        } else if constexpr (std::is_same_v<T, AnyOfSpec>) {
+          for (const auto& opt : s.options) {
+            auto r = MustBeObject(opt, resolver, visited_refs);
+            if (r.IsErr()) return ResultErr(std::move(r).UnwrapErr());
+            if (!std::move(r).Unwrap()) return ResultOk(false);
+          }
+          return ResultOk(!s.options.empty());
+        } else if constexpr (std::is_same_v<T, AllOfSpec>) {
+          for (const auto& sub : s.schemas) {
+            auto r = MustBeObject(sub, resolver, visited_refs);
+            if (r.IsErr()) return ResultErr(std::move(r).UnwrapErr());
+            if (std::move(r).Unwrap()) return ResultOk(true);
+          }
+          return ResultOk(false);
+        } else if constexpr (std::is_same_v<T, RefSpec>) {
+          if (visited_refs.count(s.uri)) {
+            return ResultErr<SchemaError>(
+                SchemaErrorType::kUnsatisfiableSchema,
+                "tool-call arguments schema has a $ref cycle; cannot verify an object root"
+            );
+          }
+          visited_refs.insert(s.uri);
+          auto resolved = resolver(s.uri, "root");
+          auto r = MustBeObject(resolved, resolver, visited_refs);
+          visited_refs.erase(s.uri);
+          return r;
+        } else {
+          // Integer/Number/String/Boolean/Null: never an object.
+          return ResultOk(false);
+        }
+      },
+      spec->spec
+  );
+}
+
+// Enforce that the ROOT schema produces a JSON object. Any at the root is
+// coerced to an empty open object; other scalar/array roots error.
+Result<SchemaSpecPtr, SchemaError> EnsureObjectRoot(
+    const SchemaSpecPtr& root, const JSONSchemaConverter::RefResolver& resolver
+) {
+  std::unordered_set<std::string> visited_refs;
+  // AnySpec at the root is coerced to an empty open object.
+  if (std::holds_alternative<AnySpec>(root->spec)) {
+    ObjectSpec obj;
+    obj.allow_additional_properties = true;
+    obj.additional_properties_schema = SchemaSpec::Make(AnySpec{}, "{}", "any");
+    return ResultOk(SchemaSpec::Make(std::move(obj), "", "root"));
+  }
+  auto r = MustBeObject(root, resolver, visited_refs);
+  if (r.IsErr()) return ResultErr(std::move(r).UnwrapErr());
+  if (!std::move(r).Unwrap()) {
+    return ResultErr<SchemaError>(
+        SchemaErrorType::kUnsatisfiableSchema,
+        "tool-call arguments must be a JSON object; schema forbids an object root"
+    );
+  }
+  return ResultOk(root);
+}
