+
+bool LiteralMatchesForbidden(const std::string& literal, const std::string& forbidden_chars) {
+  if (forbidden_chars.empty() || literal.empty()) return false;
+  RegexConverter converter(/*regex=*/"", forbidden_chars);
+  for (TCodepoint c : ParseUTF8(literal.c_str(), false)) {
+    if (c != kInvalidUTF8 && converter.IsForbidden(c)) return true;
+  }
+  return false;
+}
