+
+std::string JSONSchemaConverter::StringPatternForbiddenChars() const {
+  if (in_bare_key_mode_) {
+    return bare_key_pattern_forbidden_;
+  }
+  if (string_value_delimiter_token_id_ >= 0) {
+    return R"(\\\x00-\x1F)";
+  }
+  return R"(\"\\\x00-\x1F)";
