+std::optional<ISTError> StructuralTagTokenResolver::ResolveJSONSchemaFormat(JSONSchemaFormat* fmt) {
+  if (!fmt->string_value_delimiter_token.has_value() && fmt->string_value_exclude_tokens.empty()) {
+    return std::nullopt;
+  }
+  if (!tokenizer_info_) {
+    return ISTError("string_value_delimiter_token requires tokenizer_info");
+  }
+  const auto& vocab = tokenizer_info_->GetDecodedVocab();
+  auto resolve_token = [&vocab](const std::string& token) -> int32_t {
+    for (int32_t i = 0; i < static_cast<int32_t>(vocab.size()); ++i) {
+      if (vocab[i] == token) {
+        return i;
+      }
+    }
+    return -1;
+  };
+  // The string delimiter is a single special token, referenced by token ID so
+  // the grammar matches the model's natural token even when the tokenizer marks
+  // it special (masked). There is no byte-literal fallback: a missing token is a
+  // hard error, never a silent re-tokenization off the model's post-trained tokens.
+  if (fmt->string_value_delimiter_token.has_value()) {
+    const auto& delimiter = *fmt->string_value_delimiter_token;
+    if (std::holds_alternative<int32_t>(delimiter)) {
+      fmt->resolved_string_value_delimiter_token_id_ = std::get<int32_t>(delimiter);
+    } else {
+      const std::string& delimiter_str = std::get<std::string>(delimiter);
+      int32_t id = resolve_token(delimiter_str);
+      if (id < 0) {
+        return ISTError(
+            "string_value_delimiter_token requires the " + delimiter_str +
+            " string-delimiter token in the tokenizer vocabulary, but it was not found"
+        );
+      }
+      fmt->resolved_string_value_delimiter_token_id_ = id;
+    }
+  }
+  // Tokens the string body must never contain (e.g. tool-call section markers).
+  // Unlike the delimiter -- which the grammar structurally requires -- an excluded
+  // token the tokenizer does not encode as a single token is simply skipped, so a
+  // split marker is not a hard error.
+  fmt->resolved_string_value_exclude_token_ids_.clear();
+  for (const auto& excluded : fmt->string_value_exclude_tokens) {
+    if (std::holds_alternative<int32_t>(excluded)) {
+      fmt->resolved_string_value_exclude_token_ids_.push_back(std::get<int32_t>(excluded));
+    } else {
+      int32_t id = resolve_token(std::get<std::string>(excluded));
+      if (id >= 0) {
+        fmt->resolved_string_value_exclude_token_ids_.push_back(id);
+      }
+    }
+  }
+  return std::nullopt;
+}
