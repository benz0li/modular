+
+std::string JSONSchemaConverter::GenerateStringLengthBody(int min_length, int max_length) const {
+  if (!in_bare_key_mode_ && string_value_delimiter_token_id_ >= 0) {
+    const std::string exclude = "ExcludeToken(" + ExcludeStringContentArgs() + ")";
+    if (max_length == -1) {
+      return exclude + "{" + std::to_string(min_length) + "} " + exclude + "*";
+    }
+    if (min_length == 0) {
+      return exclude + "{0," + std::to_string(max_length) + "}";
+    }
+    return exclude + "{" + std::to_string(min_length) + "} " + exclude + "{0," +
+           std::to_string(max_length - min_length) + "}";
+  }
+  std::string char_class =
+      in_bare_key_mode_ ? "[^" + bare_key_pattern_forbidden_ + "]" : "[^\"\\\\\\r\\n]";
+  std::string repetition = max_length == -1
+                               ? "{" + std::to_string(min_length) + ",}"
+                               : "{" + std::to_string(min_length) + "," +
+                                     std::to_string(max_length) + "}";
+  return char_class + repetition;
+}
