+
+std::string JSONSchemaConverter::RenderJSONValueLiteral(const picojson::value& v) const {
+  if (v.is<std::string>()) {
+    std::string json = v.serialize();
+    return WrapValueStringLiteral(json.substr(1, json.size() - 2));
+  }
+  if (v.is<picojson::array>()) {
+    const auto& arr = v.get<picojson::array>();
+    std::string body = "\"[\"";
+    for (size_t i = 0; i < arr.size(); ++i) {
+      body += (i == 0 ? std::string(" ") : " \"" + item_sep_ + "\" ") + RenderJSONValueLiteral(arr[i]);
+    }
+    body += " \"]\"";
+    return "(" + body + ")";
+  }
+  if (v.is<picojson::object>()) {
+    const auto& obj = v.get<picojson::object>();
+    std::string body = "\"{\"";
+    bool first = true;
+    for (const auto& key : obj.ordered_keys()) {
+      std::string kjson = picojson::value(key).serialize();
+      body += (first ? std::string(" ") : " \"" + item_sep_ + "\" ") +
+              WrapValueKeyLiteral(kjson.substr(1, kjson.size() - 2)) + " \"" + colon_sep_ + "\" " +
+              RenderJSONValueLiteral(obj.at(key));
+      first = false;
+    }
+    body += " \"}\"";
+    return "(" + body + ")";
+  }
+  return "\"" + v.serialize() + "\"";
+}
