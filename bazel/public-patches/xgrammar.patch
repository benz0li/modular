+std::optional<SchemaError> SchemaParser::CheckUnsupportedKeywords(
+    const picojson::object& schema, const std::vector<std::string>& keywords
+) {
+  if (!config_.reject_unsupported) {
+    WarnUnsupportedKeywords(schema, keywords);
+    return std::nullopt;
+  }
+  for (const auto& keyword : keywords) {
+    if (schema.find(keyword) != schema.end()) {
+      return SchemaError(
+          SchemaErrorType::kUnsatisfiableSchema, "unsupported schema keyword: " + keyword
+      );
+    }
+  }
+  return std::nullopt;
+}
