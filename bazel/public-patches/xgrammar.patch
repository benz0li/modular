+// Keywords that impose no enforceable constraint: annotations
+// plus core/identifier bookkeeping (URIs, dialect, $defs containers,
+// anchor definitions) that only take effect when referenced elsewhere.
+static const std::unordered_set<std::string>& NoConstraintKeywords() {
+  static const std::unordered_set<std::string> kNoConstraintKeywords = {
+      "title",       "description",  "default",           "examples",
+      "$comment",    "readOnly",     "writeOnly",         "deprecated",
+      "$id",         "$schema",      "$defs",             "definitions",
+      "$anchor",     "$vocabulary",  "$dynamicAnchor",    "$recursiveAnchor",
+      "contentEncoding", "contentMediaType", "contentSchema",
+      "if",          "then",         "else"};
+  return kNoConstraintKeywords;
+}
+
+static bool IsNoConstraintKeyword(const std::string& key) {
+  return NoConstraintKeywords().count(key) > 0;
+}
+
+static bool SubschemaIsNoOp(const picojson::value& v) {
+  if (v.is<bool>()) return v.get<bool>();
+  if (!v.is<picojson::object>()) return false;
+  const auto& o = v.get<picojson::object>();
+  if (o.count("if") && (o.count("then") || o.count("else"))) return false;
+  for (const auto& k : o.ordered_keys()) {
+    if (!IsNoConstraintKeyword(k)) return false;
+  }
+  return true;
+}
